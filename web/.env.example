# Copy to web/.env.local for local development. Vercel reads its own values
# from the dashboard env vars in production.

# Backend (Railway in prod, local FastAPI in dev). Must include scheme + host.
# Note: the Data360 MCP also runs on 8000 in local dev (see ../CLAUDE.md), so
# Verifacta's API uses 8001 to avoid colliding. In Phase 1 the MCP moves to a
# stdio subprocess and this distinction disappears.
NEXT_PUBLIC_API_URL=http://localhost:8001

# HTTP Basic Auth covering every page. Set in Vercel for production.
# Leave unset in local dev to skip auth (middleware allows it in NODE_ENV=development).
# JURY_USER=jury
# JURY_PASS=change-me
