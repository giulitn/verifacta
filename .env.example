# Copy this file to .env and fill in the API key for the provider you want to use.
# .env is gitignored.

# --- Provider selection ---------------------------------------------------
# Format: "<provider>:<model_id>". Consumed by langchain.chat_models.init_chat_model.
# Default if unset: groq:llama-3.3-70b-versatile (free, fast, supports tool calling).
# Examples:
#   VERIFACTA_MODEL=cerebras:llama-3.3-70b          # 1M tokens/day free, ~2000 tok/s
#   VERIFACTA_MODEL=groq:llama-3.3-70b-versatile    # 100k tokens/day free
#   VERIFACTA_MODEL=anthropic:claude-sonnet-4-6     # paid, highest quality
#   VERIFACTA_MODEL=google_genai:gemini-2.0-flash   # free tier with strict daily caps
#   VERIFACTA_MODEL=openai:gpt-4o-mini              # paid
# VERIFACTA_MODEL=

# --- Data360 MCP server ---------------------------------------------------
# URL of the official World Bank Data360 MCP server, running locally. Start
# it with `uv run poe serve --port 8000 --transport http` in a clone of
# https://github.com/worldbank/data360-mcp.
# DATA360_MCP_URL=http://localhost:8000/mcp

# --- HTTP API (Phase 0 onwards) -------------------------------------------
# Origin (scheme + host) of the Next.js frontend allowed by CORS. Leave
# unset locally to use the localhost default baked into api.py.
# FRONTEND_ORIGIN=https://verifacta.vercel.app

# --- Observability (Datadog LLM Observability) ----------------------------
# Get an API key at https://app.datadoghq.com/organization-settings/api-keys.
# When DD_API_KEY is unset the agent runs normally with no tracing.
# DD_API_KEY=
# Datadog region — datadoghq.com (US1, default), datadoghq.eu (EU1),
# us3.datadoghq.com, us5.datadoghq.com, ap1.datadoghq.com.
# DD_SITE=datadoghq.com
# ML app name shown in Datadog LLM Obs UI.
# DD_LLMOBS_ML_APP=verifacta
# Required on Railway / Vercel / local Mac (no Datadog Agent on the host).
# DD_LLMOBS_AGENTLESS_ENABLED=true

# --- Provider API keys (set the one matching your VERIFACTA_MODEL) --------

# Cerebras — https://cloud.cerebras.ai (free 1M tokens/day, no credit card)
CEREBRAS_API_KEY=

# Groq — https://console.groq.com/keys (free tier, no credit card)
GROQ_API_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey (free tier)
# GOOGLE_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=
